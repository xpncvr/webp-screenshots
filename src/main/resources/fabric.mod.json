{
	"schemaVersion": 1,
	"id": "webpscreenshots",
	"version": "${version}",
	"name": "WebP Screenshots",
	"description": "This Minecraft mod changes the file format for screenshots to a more efficient format WebP to save space while not degrading quality",
	"authors": [
		"xpncvr"
	],
	"contact": {
		"homepage": "https://github.com/xpncvr/webp-screenshots",
		"sources": "https://github.com/xpncvr/webp-screenshots"
	},
	"license": "GPL-3.0",
	"icon": "assets/webpscreenshots/icon.png",
	"mixins": [
		"webpscreenshots.mixins.json"
	],
	"depends": {
		"minecraft": "~1.21.10",
		"java": ">=21"
	},
    "entrypoints": {
      "main": [
        "xpncvr.webp.screenshots.Main"
      ]
    }
}